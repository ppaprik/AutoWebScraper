#======================================================================================================
# Copy this file to .env and fill in your values
#======================================================================================================

# --- PostgreSQL ---
POSTGRES_USER=webscraper
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=webscraper
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
API_RELOAD=false

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=4

# --- Scraper Defaults ---
SCRAPER_DEFAULT_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=5
SCRAPER_USER_AGENT=WebScraper/1.0
SCRAPER_MAX_CONCURRENT_REQUESTS=10
SCRAPER_RESPECT_ROBOTS_TXT=true
SCRAPER_DEFAULT_DELAY_BETWEEN_REQUESTS=1.0
